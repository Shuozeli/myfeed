# Chrome CDP endpoint (pwright connects here)
CDP_ENDPOINT=http://localhost:9222

# SQLite database path
DATABASE_URL=myfeed.db

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_CHAT_ID=your-chat-id

# Scheduler
CRAWL_INTERVAL_SECS=1800

# Sites to crawl (comma-separated)
ENABLED_SITES=reddit,zhihu,xueqiu,x,linkedin,hackernews,1point3acres

# Atom feed output (optional, unset = disabled)
# FEED_OUTPUT_PATH=feed.xml
# FEED_ITEM_COUNT=100

# Keyword filter (optional, comma-separated, case-insensitive)
# Only items matching a keyword are sent to Telegram.
# All items are still saved to DB for snapshots and dump.
# FILTER_KEYWORDS=AI,rust,immigration,tariff,interview

# Digest mode (optional, default false)
# true = batch new items into one Telegram message per site per cycle
# false = one Telegram message per item (default)
# DIGEST_MODE=true

# Dedup window (optional, default 0 = forever, never re-notify)
# Set to N hours to allow re-notification after N hours
# DEDUP_WINDOW_HOURS=0

# Per-site dedup overrides (optional, comma-separated site:hours pairs)
# Useful for trending/hot feeds where the same topic reappearing is news
# DEDUP_OVERRIDES=weibo-hot:24,github-trending:48
